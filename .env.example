# n8n Instance Configuration
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# Your n8n instance URL (without trailing slash)
N8N_URL=https://your-n8n-instance.example.com

# API Key from n8n (Settings > API > Create API Key)
N8N_API_KEY=your-api-key-here

# OpenAI API Key (for AI content generation)
OPENAI_API_KEY=your-openai-api-key-here

# OpenAI Model (optional, defaults to gpt-4o-mini)
# Options: gpt-4o-mini (cheapest), gpt-4o, gpt-4-turbo
OPENAI_MODEL=gpt-4o-mini

# Company description for AI content generation (Arabic or English)
LINKEDIN_COMPANY_DESCRIPTION=وصف شركتك ومجال عملها هنا
