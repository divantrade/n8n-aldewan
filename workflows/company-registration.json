      "id": "b2c3d4e5-srch-4567-8901-searchfolders1",
      "name": "Search Type Folders",
      "executeOnce": false,
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "Qxvp2her5WCwbXIO",
          "name": "Google Drive account"
        }
      },
