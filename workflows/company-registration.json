      "id": "8e6ae91c-cccf-4f92-b617-8d2141a9bb87",
      "name": "Search inside new company",
      "credentials": {
        "googleDriveOAuth2Api": {
          "id": "Qxvp2her5WCwbXIO",
          "name": "Google Drive account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ===== CONFIG =====\nconst CONFIG = {\n  Limited_Company: {\n    parentId: '1J-Gd-7w_jkWviJVfAeXxhz3ADS1CEIwx',\n    sheetGid: 0\n  },\n  personal_Company: {\n    parentId: '1DrkXAhpOUpyWpp2gvlGCpe2MC_lt_veq',\n    sheetGid: 206423802\n  },\n  Taxpayers: {\n    parentId: '1Ue1FAta0dBCJ-nIceVwogQb9DrnVO__L',\n    sheetGid: 1617195523\n  }\n};\n\n// ===== HELPERS =====\nconst normalize = (str = '') =>\n  str\n    .toLowerCase()\n    .normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/ı/g, 'i')\n    .replace(/ş/g, 's')\n    .replace(/ğ/g, 'g')\n    .replace(/ü/g, 'u')\n    .replace(/ö/g, 'o')\n    .replace(/ç/g, 'c')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\nconst stripPdfExt = (name = '') => name.replace(/\\.pdf$/i, '').trim();\n\nconst cleanCompanyName = (raw = '') => {\n  let base = stripPdfExt(raw)\n    .replace(/\\s*\\.\\s*/g, ' ')\n    .replace(/\\s+/g, ' ')\n    .trim();\n\n  const splitter = /([ \\t,؛;:()|/\\-–—]+)/;\n  const parts = base.split(splitter);\n  const out = [];\n\n  for (let i = 0; i < parts.length; i++) {\n    const token = parts[i];\n    if (splitter.test(token)) {\n      out.push(token);\n      continue;\n    }\n\n    const nTok = normalize(token);\n    const nextToken = parts[i + 2] ?? '';\n    const nextSep = parts[i + 1] ?? '';\n    const nNextTok = normalize(nextToken);\n\n    const singleStops = new Set([\n      'limited', 'ltd', 'company',\n      'tasfiye', 'halinde',\n      'sahsi', 'sahis',\n      'tax', 'payer', 'payers'\n    ]);\n\n    const twoWordStops = new Set([\n      'limited company',\n      'tasfiye halinde',\n      'tax payer',\n      'tax payers'\n    ]);\n\n    const isTwoWordCombo =\n      nextSep && splitter.test(nextSep) &&\n      twoWordStops.has(`${nTok} ${nNextTok}`);\n\n    if (isTwoWordCombo) {\n      i += 2;\n      continue;\n    }\n\n    if (singleStops.has(nTok)) {\n      continue;\n    }\n\n    out.push(token);\n  }\n\n  return out.join('')\n    .replace(/\\s+/g, ' ')\n    .replace(/\\s*[,؛;:()|/\\-–—]\\s*$/g, '')\n    .replace(/^[,؛;:()|/\\-–—]\\s*/g, '')\n    .trim();\n};\n\nconst classify = (name = '') => {\n  const n = normalize(name);\n  const isLimited =\n    /\\blimited\\s+company\\b/.test(n) ||\n    /\\blimited\\b/.test(n) ||\n    /\\bltd\\b/.test(n) ||\n    /\\btasfiye\\s+halinde\\b/.test(n);\n  const isPersonal = /\\bsahsi\\b/.test(n) || /\\bsahis\\b/.test(n);\n\n  if (isLimited) return 'Limited_Company';\n  if (isPersonal) return 'personal_Company';\n  return 'Taxpayers';\n};\n\n// ===== MAIN =====\nconst items = $input.all();\n\nreturn items.map((item) => {\n  const fileName = item.json?.name ?? item.json?.fileName ?? '';\n  const originalId = item.json?.id ?? item.json?.fileId ?? null;\n  const companyType = classify(fileName);\n  const companyName = cleanCompanyName(fileName);\n  const normalizedName = normalize(companyName);\n  const parentFolderId = CONFIG[companyType].parentId;\n  const newFolderName = 'TAX ' + companyName;\n  const normalizedFolderName = normalize(newFolderName);\n\n  return {\n    json: {\n      id: originalId,\n      name: fileName,\n      companyName,\n      normalizedName,\n      companyType,\n      parentFolderId,\n      newFolderName,\n      normalizedFolderName,\n      normalizedCompanyName: normalizedName\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -480,
        300
      ],
      "id": "27801e06-3dd5-40d4-9fd6-7c6d0d0eedd2",
      "name": "Classify & Normalize Companies"
    },
    {
      "parameters": {
        "jsCode": "// Phase 1: Search existing folders for each company type\n// and match companies to their folders\n\nconst CONFIG = {\n  Limited_Company: '1J-Gd-7w_jkWviJVfAeXxhz3ADS1CEIwx',\n  personal_Company: '1DrkXAhpOUpyWpp2gvlGCpe2MC_lt_veq',\n  Taxpayers: '1Ue1FAta0dBCJ-nIceVwogQb9DrnVO__L'\n};\n\nconst companies = $input.all().map(i => i.json);\n\n// Group by type\nconst grouped = {};\nfor (const c of companies) {\n  if (!grouped[c.companyType]) grouped[c.companyType] = [];\n  grouped[c.companyType].push(c);\n}\n\n// We pass the grouped data + config for the next node to use\nreturn companies.map(c => ({\n  json: {\n    ...c,\n    parentFolderQuery: `='${CONFIG[c.companyType]}' in parents and mimeType = 'application/vnd.google-apps.folder' and trashed = false`\n  }\n}));"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -240,
        300
      ],
      "id": "a1b2c3d4-prep-4567-8901-preparequery01",
      "name": "Prepare Folder Queries"
    },
    {
      "parameters": {
        "resource": "fileFolder",
        "searchMethod": "query",
        "queryString": "='{{ $json.parentFolderId }}' in parents and mimeType = 'application/vnd.google-apps.folder' and trashed = false",
