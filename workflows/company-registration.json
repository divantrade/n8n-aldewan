    {
      "parameters": {
        "jsCode": "// Match companies with existing folders\n// Input 1 (index 0) = companies from 'Prepare Folder Queries'\n// Input 2 (index 1) = folder search results from 'Search Type Folders'\n\nconst companies = $('Classify & Normalize Companies').all().map(i => i.json);\nconst allFolders = $input.all().map(i => i.json);\n\nconst normalize = (str = '') =>\n  str.toLowerCase().normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/ı/g, 'i').replace(/ş/g, 's')\n    .replace(/ğ/g, 'g').replace(/ü/g, 'u')\n    .replace(/ö/g, 'o').replace(/ç/g, 'c')\n    .replace(/\\s+/g, ' ').trim();\n\nconst results = companies.map(company => {\n  // Find matching folder by normalized name\n  const match = allFolders.find(f => {\n    if (!f.name) return false;\n    return normalize(f.name) === normalize(company.companyName);\n  });\n\n  return {\n    json: {\n      ...company,\n      folderId: match ? match.id : null,\n      folderFound: !!match\n    }\n  };\n});\n\nreturn results;"
      },
