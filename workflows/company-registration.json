    {
      "parameters": {
        "jsCode": "// Check if TAX folder exists for each company\n// Match by parent folder ID (reliable) + fallback to name matching\n\nconst companies = $('Merge All Companies').all().map(i => i.json);\nconst taxSearchResults = $input.all().map(i => i.json);\n\nconst normalize = (str = '') =>\n  str.toLowerCase().normalize('NFD')\n    .replace(/[\\u0300-\\u036f]/g, '')\n    .replace(/ı/g, 'i').replace(/ş/g, 's')\n    .replace(/ğ/g, 'g').replace(/ü/g, 'u')\n    .replace(/ö/g, 'o').replace(/ç/g, 'c')\n    .replace(/\\s+/g, ' ').trim();\n\nreturn companies.map(company => {\n  // Primary match: by parent folder ID (TAX folder should be inside the company folder)\n  let matchedTax = taxSearchResults.find(folder => {\n    if (!folder.id || !company.folderId) return false;\n    // Google Drive returns parents array\n    const parents = folder.parents || [];\n    return parents.includes(company.folderId);\n  });\n\n  // Fallback: match by normalized name\n  if (!matchedTax) {\n    matchedTax = taxSearchResults.find(folder => {\n      if (!folder.name) return false;\n      return normalize(folder.name) === normalize(company.newFolderName);\n    });\n  }\n\n  return {\n    json: {\n      ...company,\n      taxFolderId: matchedTax ? matchedTax.id : null,\n      taxFolderExists: !!matchedTax\n    }\n  };\n});"
      },
