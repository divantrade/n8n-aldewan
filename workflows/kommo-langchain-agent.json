    {
      "parameters": {
        "jsCode": "// Loop over input items and add a new field called 'myNewField' to the JSON of each one\nfor (const item of $input.all()) {\n  item.json.myNewField = 1;\n}\n\nreturn $input.all();"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        688,
        -176
      ],
      "id": "518520fb-b44b-4751-a7d1-bb79430f7971",
      "name": "Code in JavaScript"
    },
    {
      "parameters": {
        "jsCode": "// n8n Code node (JavaScript) — Kommo webhook normalizer (stable)\n\n// helpers\nfunction pick(...arr) {\n  return arr.find(v => v !== undefined && v !== null && v !== '');\n}\nfunction read(obj, path) {\n  return path.split('][').reduce((acc, key) => {\n    key = key.replace(/^\\[|\\]$/g, '');\n    return acc && acc[key] !== undefined ? acc[key] : undefined;\n  }, obj);\n}\nfunction originNormalize(v) {\n  const s = (v ?? '').toString().toLowerCase().trim();\n  const map = {\n    waba: 'wa', whatsapp: 'wa', wa: 'wa',\n    instagram: 'ig', ig: 'ig',\n    facebook: 'fb', fb: 'fb',\n    telegram: 'tg', tg: 'tg',\n    mail: 'email', email: 'email',\n    website: 'livechat', livechat: 'livechat'\n  };\n  return map[s] || s;\n}\n\nreturn items.map(item => {\n  const j = item.json || {};\n  const b = j.body || {};\n\n  // 1) event_type (شامل كل الأنواع اللي ظهرت معنا)\n // --- event_type (prefix-based detection for flat keys) ---\nconst keys = Object.keys(b || {});\nconst has = (p) => keys.some(k => k.startsWith(p));\n\nlet event_type = 'unknown';\nif (has('message[add]')) event_type = 'message[add]';\nelse if (has('message[update]')) event_type = 'message[update]';\nelse if (has('talk[add]')) event_type = 'talk[add]';\nelse if (has('talk[update]')) event_type = 'talk[update]';\nelse if (has('unsorted[add]')) event_type = 'unsorted[add]';\nelse if (has('unsorted[update]')) event_type = 'unsorted[update]';\nelse if (has('unsorted[delete]')) event_type = 'unsorted[delete]';\nelse if (has('leads[update]')) event_type = 'leads[update]';\nelse if (has('leads[responsible]')) event_type = 'leads[responsible]';\nelse if (has('leads[delete]')) event_type = 'leads[delete]';\nelse if (has('contacts[add]')) event_type = 'contacts[add]';\nelse if (has('contacts[update]')) event_type = 'contacts[update]';\nelse if (has('task[add]')) event_type = 'task[add]';\nelse if (has('task[delete]')) event_type = 'task[delete]';\n  \n  // 2) IDs الأساسية\n  const lead_id_raw = pick(\n    b['leads[update][0][id]'],\n    b['leads[responsible][0][id]'],\n    b['leads[delete][0][id]'],\n    b['talk[update][0][entity_id]'],\n    b['talk[add][0][entity_id]'],\n    b['unsorted[add][0][lead_id]'],\n    read(b, 'unsorted[update][0][data][leads][0][id]'),\n    // unsorted delete: accept / decline\n    read(b, 'unsorted[delete][0][accept_result][leads][0]'),\n    read(b, 'unsorted[delete][0][decline_result][leads][0]'),\n    b['message[add][0][entity_id]'],\n    b['task[add][0][element_id]'],\n    ''\n  );\n  const lead_id = (lead_id_raw === '0' || lead_id_raw === 0) ? '' : (lead_id_raw || '');\n\n  const chat_id = pick(\n    b['talk[update][0][chat_id]'],\n    b['talk[add][0][chat_id]'],\n    read(b, 'unsorted[add][0][source_data][origin][chat_id]'),\n    read(b, 'unsorted[update][0][source_data][origin][chat_id]'),\n    b['message[add][0][chat_id]'],\n    ''\n  ) || '';\n\n  const message_id = pick(\n    b['message[add][0][id]'],\n    read(b, 'unsorted[add][0][source_data][data][0][id]'),\n    read(b, 'unsorted[update][0][source_data][data][0][id]'),\n    ''\n  ) || '';\n\n  const task_id = pick(\n    b['task[add][0][id]'],\n    b['task[delete][0][id]'],\n    ''\n  ) || '';\n\n  const message_text =\n    pick(\n      b['message[add][0][text]'],\n      read(b,'unsorted[add][0][source_data][data][0][text]'),\n      read(b,'unsorted[update][0][source_data][data][0][text]')\n    ) || '';\n\n  // 3) origin/channel موحد\n  const originCandidate = pick(\n    b['message[add][0][origin]'],\n    b['message[update][0][origin]'],\n    b['talk[add][0][origin]'],\n    b['talk[update][0][origin]'],\n    b['unsorted[add][0][origin]'],\n    b['unsorted[update][0][origin]'],\n    b['leads[update][0][origin]'],\n    b['leads[responsible][0][origin]'],\n    b['message[add][0][provider]'],\n    b['unsorted[add][0][provider]'],\n    b['talk[update][0][provider]'],\n    b['message[add][0][channel]'],\n    b['unsorted[add][0][channel]'],\n    b['talk[update][0][channel]'],\n    read(b,'unsorted[add][0][source_data][service]'),\n    read(b,'unsorted[update][0][source_data][service]'),\n    ''\n  );\n  const message_origin = originNormalize(originCandidate);\n\n  // 4) Timestamp موحد (Unix sec إن وُجد، أو string تاريخي)\n  const rawTs = pick(\n    b['message[add][0][created_at]'],\n    b['message[update][0][updated_at]'],\n    b['talk[add][0][created_at]'],\n    b['talk[update][0][updated_at]'],\n    b['unsorted[add][0][created_at]'],\n    b['unsorted[update][0][created_at]'],\n    read(b,'unsorted[add][0][source_data][date]'),\n    read(b,'unsorted[update][0][source_data][data][0][date]'),\n    b['leads[update][0][updated_at]'],\n    (b['leads[responsible][0][updated_at]'] || b['leads[responsible][0][last_modified]']),\n    (b['task[add][0][updated_at]'] || b['task[add][0][created_at]'] || b['task[add][0][complete_before]'] || b['task[add][0][last_modified]'] || b['task[add][0][date_create]']),\n    '' // leads[delete] / task[delete] غالبًا بلا توقيت\n  ) || '';\n\n  let event_ts_unix = '';\n  if (typeof rawTs === 'string' && rawTs.includes('-')) {\n    const ms = Date.parse(rawTs.replace(' ', 'T') + 'Z'); // اعتبره UTC\n    if (!isNaN(ms)) event_ts_unix = Math.floor(ms / 1000).toString();\n  } else {\n    const n = Number(rawTs);\n    if (!isNaN(n) && n > 0) event_ts_unix = String(n);\n  }\n  const event_time_utc = event_ts_unix ? new Date(Number(event_ts_unix) * 1000).toISOString() : '';\n  const event_time_istanbul = event_ts_unix\n    ? new Date(Number(event_ts_unix) * 1000).toLocaleString('tr-TR', { timeZone: 'Europe/Istanbul' })\n    : '';\n\n  // 5) السجل النهائي (جاهز للمابينج على Google Sheets)\n  const record = {\n    raw_data: JSON.stringify(b),\n    event_type,\n    event_ts_unix,\n    event_time_utc,\n    event_time_istanbul,\n    lead_id,\n    chat_id,\n    message_id,\n    message_text,\n    message_origin,\n    webhookUrl: j.webhookUrl || '',\n    executionMode: j.executionMode || '',\n    received_at_utc: new Date().toISOString(),\n    processed: false,\n    task_id,\n  };\n\n  return { json: record };\n});"
      },
