    {
      "parameters": {
        "jsCode": "// استخراج المحتوى المولّد وتجهيزه للكتابة في Google Sheets\nconst item = $input.first();\nconst aiResponse = item.json;\n\n// استخراج النص المولّد من رد OpenAI\nconst generatedContent = aiResponse.choices?.[0]?.message?.content || '';\n\nif (!generatedContent) {\n  throw new Error('لم يتم توليد محتوى. تأكد من صحة مفتاح OpenAI API.');\n}\n\nreturn [{\n  json: {\n    rowNumber: item.json.rowNumber || item.json.__rowNumber || item.json['row_number'] || '',\n    'المحتوى': generatedContent,\n    'content': generatedContent,\n    'الحالة': 'مسودة',\n    'status': 'draft',\n    'الموضوع': item.json.topic || '',\n    'topic': item.json.topic || ''\n  }\n}];"
      },
