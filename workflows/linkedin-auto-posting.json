    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "genericCredentialType",
        "genericAuthType": "httpHeaderAuth",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Content-Type",
              "value": "application/json"
            }
          ]
        },
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"{{ $env.OPENAI_MODEL || 'gpt-4o-mini' }}\",\n  \"messages\": [\n    {\n      \"role\": \"system\",\n      \"content\": \"أنت كاتب محتوى محترف متخصص في LinkedIn. تكتب منشورات جذابة واحترافية.\"\n    },\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.generatedPrompt) }}\n    }\n  ],\n  \"temperature\": 0.7,\n  \"max_tokens\": 1000\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "b2c3d4e5-2222-5555-bbbb-000000000005",
      "name": "توليد المحتوى بالذكاء الاصطناعي",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
