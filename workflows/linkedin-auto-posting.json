    {
      "parameters": {
        "jsCode": "// تجهيز البرومبت لتوليد محتوى LinkedIn\nconst item = $input.first();\nconst topic = item.json['الموضوع'] || item.json['topic'] || item.json['العنوان'] || item.json['title'] || '';\nconst tone = item.json['النبرة'] || item.json['tone'] || 'احترافي';\nconst language = item.json['اللغة'] || item.json['language'] || 'ar';\nconst companyDescription = $env.LINKEDIN_COMPANY_DESCRIPTION || 'شركة متخصصة';\nconst contentNotes = item.json['ملاحظات'] || item.json['notes'] || '';\n\nconst langInstruction = language === 'en' \n  ? 'Write the post in English.' \n  : language === 'both' \n    ? 'Write the post in both Arabic and English.'\n    : 'اكتب المنشور باللغة العربية.';\n\nconst prompt = `أنت خبير في كتابة محتوى LinkedIn احترافي وجذاب.\n\nمعلومات الشركة: ${companyDescription}\n\nالمطلوب: اكتب منشور LinkedIn عن الموضوع التالي:\nالموضوع: ${topic}\nالنبرة المطلوبة: ${tone}\n${contentNotes ? 'ملاحظات إضافية: ' + contentNotes : ''}\n${langInstruction}\n\nالقواعد:\n- اكتب منشور بطول 150-300 كلمة\n- استخدم أسلوب جذاب يشجع على التفاعل\n- أضف 3-5 هاشتاقات مناسبة في النهاية\n- أضف سؤال في النهاية لتشجيع التعليقات\n- لا تستخدم إيموجي بشكل مبالغ فيه (2-4 كحد أقصى)\n- اجعل المنشور عملي ويقدم قيمة حقيقية\n\nاكتب المنشور فقط بدون أي مقدمات أو تعليقات.`;\n\nreturn [{\n  json: {\n    ...item.json,\n    generatedPrompt: prompt,\n    topic: topic,\n    tone: tone,\n    language: language\n  }\n}];"
      },
