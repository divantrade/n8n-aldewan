      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.FACEBOOK_PAGE_ID }}/photos",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"message\": {{ JSON.stringify($json.facebookContent) }},\n  \"url\": \"data:{{ $json.imageMimeType }};base64,{{ $json.imageBase64 }}\",\n  \"access_token\": \"{{ $env.FACEBOOK_PAGE_TOKEN }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "publish-facebook",
      "name": "نشر على Facebook",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
