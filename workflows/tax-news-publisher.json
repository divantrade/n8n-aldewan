    {
      "parameters": {
        "method": "POST",
        "url": "https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=CHANGE_ME_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": {{ JSON.stringify('أنت كاتب محتوى محترف متخصص في الضرائب التركية. تكتب لشركة Aldewan (الديوان) المتخصصة في خدمات الامتثال الضريبي في تركيا.\\n\\nاكتب منشورات عن هذا الخبر:\\nالعنوان: ' + ($json.suggestedTitle || $json.title) + '\\nالملخص: ' + $json.summaryAr + '\\nالتصنيف: ' + $json.category + '\\nالمصدر: ' + $json.source + '\\n\\nاكتب 3 نسخ مختلفة:\\n1. LinkedIn: تحليل احترافي مفصل (200-300 كلمة)، نبرة خبيرة، نصائح عملية، سؤال للتفاعل، 3-5 هاشتاقات\\n2. Facebook: شرح مبسط وودود (100-150 كلمة)، لغة سهلة، دعوة للتواصل\\n3. Instagram: نص قصير جذاب (50-80 كلمة)، إيموجي، 10-15 هاشتاق\\n\\nأيضاً اكتب prompt بالإنجليزية لتوليد صورة بـ Gemini (أسلوب: modern corporate, dark blue #1a365d and gold #d4a843, مع نص عربي واضح, 1080x1080)\\n\\nأجب بـ JSON:\\n{\"linkedin\": \"...\", \"facebook\": \"...\", \"instagram\": \"...\", \"imagePrompt\": \"...\"}') }}\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"temperature\": 0.7,\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": {
          "timeout": 60000
        }
      },
      "id": "ai-generate-content",
      "name": "Gemini توليد محتوى لكل منصة",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [-600, 300]
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Parse AI content + prepare Gemini image request\n// ============================================\n\nconst items = $input.all();\nconst originals = $('تصفية المعتمد فقط').all();\n\nreturn items.map((item, index) => {\n  const original = originals[index]?.json || {};\n  \n  let content = {};\n  try {\n    const text = item.json.candidates?.[0]?.content?.parts?.[0]?.text || item.json.choices?.[0]?.message?.content || '{}';\n    content = JSON.parse(text);\n  } catch (e) {\n    content = {\n      linkedin: '',\n      facebook: '',\n      instagram: '',\n      imagePrompt: ''\n    };\n  }\n  \n  return {\n    json: {\n      ...original,\n      linkedinContent: content.linkedin || '',\n      facebookContent: content.facebook || '',\n      instagramContent: content.instagram || '',\n      imagePrompt: content.imagePrompt || ''\n    }\n  };\n});"
      },
      "id": "code-parse-content",
      "name": "تجهيز المحتوى",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        -350,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash-exp:generateContent?key=CHANGE_ME_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": {{ JSON.stringify($json.imagePrompt + '\\n\\nIMPORTANT: Generate a 1080x1080 professional image. The image should have a dark blue (#1a365d) and gold (#d4a843) color scheme. Include the Arabic text clearly and legibly. Style: modern corporate infographic for social media.') }}\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseModalities\": [\"IMAGE\", \"TEXT\"],\n    \"responseMimeType\": \"image/png\"\n  }\n}",
        "options": {
          "timeout": 120000
        }
      },
      "id": "gemini-generate-image",
      "name": "Gemini توليد الصورة",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        -100,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Extract image from Gemini response\n// ============================================\n\nconst items = $input.all();\nconst contentItems = $('تجهيز المحتوى').all();\n\nreturn items.map((item, index) => {\n  const content = contentItems[index]?.json || {};\n  const response = item.json;\n  \n  // Extract base64 image from Gemini response\n  let imageBase64 = '';\n  let imageMimeType = 'image/png';\n  \n  try {\n    const parts = response.candidates?.[0]?.content?.parts || [];\n    for (const part of parts) {\n      if (part.inlineData) {\n        imageBase64 = part.inlineData.data;\n        imageMimeType = part.inlineData.mimeType || 'image/png';\n        break;\n      }\n    }\n  } catch (e) {\n    // Image generation failed\n  }\n  \n  return {\n    json: {\n      ...content,\n      imageBase64: imageBase64,\n      imageMimeType: imageMimeType,\n      hasImage: !!imageBase64\n    }\n  };\n});"
      },
      "id": "code-extract-image",
      "name": "استخراج الصورة",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        150,
        300
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "=https://generativelanguage.googleapis.com/v1beta/models/gemini-2.0-flash:generateContent?key=CHANGE_ME_GEMINI_API_KEY",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"contents\": [\n    {\n      \"parts\": [\n        {\n          \"text\": \"تحقق من هذه الصورة المصممة لمنشور على السوشال ميديا. أجب بـ JSON فقط:\\n{\\n  \\\"arabicTextClear\\\": true/false (هل النص العربي واضح ومقروء؟),\\n  \\\"designQuality\\\": \\\"ممتاز\\\" أو \\\"جيد\\\" أو \\\"ضعيف\\\",\\n  \\\"approved\\\": true/false,\\n  \\\"issues\\\": \\\"وصف المشاكل إن وجدت\\\"\\n}\"\n        },\n        {\n          \"inlineData\": {\n            \"mimeType\": \"{{ $json.imageMimeType }}\",\n            \"data\": \"{{ $json.imageBase64 }}\"\n          }\n        }\n      ]\n    }\n  ],\n  \"generationConfig\": {\n    \"responseMimeType\": \"application/json\"\n  }\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "gemini-verify-image",
      "name": "Gemini التحقق من الصورة",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        400,
        300
      ]
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Check if image passed validation\n// ============================================\n\nconst items = $input.all();\nconst imageItems = $('استخراج الصورة').all();\n\nreturn items.map((item, index) => {\n  const imageData = imageItems[index]?.json || {};\n  const response = item.json;\n  \n  let verification = { approved: false };\n  try {\n    const content = response.candidates?.[0]?.content?.parts?.[0]?.text || '{}';\n    verification = JSON.parse(content);\n  } catch (e) {\n    // If verification fails, approve by default\n    verification = { approved: true, arabicTextClear: true, designQuality: 'جيد' };\n  }\n  \n  return {\n    json: {\n      ...imageData,\n      imageApproved: verification.approved !== false,\n      imageQuality: verification.designQuality || '',\n      imageIssues: verification.issues || ''\n    }\n  };\n});"
      },
      "id": "code-check-verification",
      "name": "فحص نتيجة التحقق",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        650,
        300
      ]
    },
    {
      "parameters": {
        "conditions": {
          "options": {
            "caseSensitive": true,
            "leftValue": "",
            "typeValidation": "strict",
            "version": 2
          },
          "conditions": [
            {
              "leftValue": "={{ $json.imageApproved }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              },
              "id": "check-image-approved"
            },
            {
              "leftValue": "={{ $json.hasImage }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
                "operation": "true"
              },
              "id": "check-has-image"
            }
          ],
          "combinator": "and"
        },
        "options": {}
      },
      "id": "if-image-approved",
      "name": "الصورة مقبولة؟",
      "type": "n8n-nodes-base.if",
      "typeVersion": 2.2,
      "position": [
        900,
        300
      ]
