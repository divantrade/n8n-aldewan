    {
      "parameters": {
        "method": "POST",
        "url": "=https://graph.facebook.com/v19.0/{{ $env.INSTAGRAM_ACCOUNT_ID }}/media",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"caption\": {{ JSON.stringify($json.instagramContent) }},\n  \"image_url\": \"data:{{ $json.imageMimeType }};base64,{{ $json.imageBase64 }}\",\n  \"access_token\": \"{{ $env.FACEBOOK_PAGE_TOKEN }}\"\n}",
        "options": {
          "timeout": 30000
        }
      },
      "id": "publish-instagram",
      "name": "نشر على Instagram",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1200,
        500
      ]
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Aggregate publishing results\n// ============================================\n\nconst linkedinResults = $('نشر على LinkedIn').all();\nconst facebookResults = $('نشر على Facebook').all();\nconst instagramResults = $('نشر على Instagram').all();\nconst contentItems = $('فحص نتيجة التحقق').all();\n\nreturn contentItems.map((item, index) => {\n  const linkedin = linkedinResults[index]?.json || {};\n  const facebook = facebookResults[index]?.json || {};\n  const instagram = instagramResults[index]?.json || {};\n  \n  const linkedinOk = linkedin.id || linkedin.activity;\n  const facebookOk = facebook.id || facebook.post_id;\n  const instagramOk = instagram.id;\n  \n  return {\n    json: {\n      title: item.json.suggestedTitle || item.json.title,\n      linkedinStatus: linkedinOk ? 'تم ✅' : 'فشل ❌',\n      facebookStatus: facebookOk ? 'تم ✅' : 'فشل ❌',\n      instagramStatus: instagramOk ? 'تم ✅' : 'فشل ❌',\n      publishedAt: new Date().toISOString(),\n      status: 'تم النشر'\n    }\n  };\n});"
      },
      "id": "code-aggregate-results",
      "name": "تجميع نتائج النشر",
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1500,
        300
      ]
    },
