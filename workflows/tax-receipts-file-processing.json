    {
      "parameters": {
        "jsCode": "// ============================================\n// Prepare AI prompt: combine PDF text with company list\n// Uses $input.all() from Merge node (PDF items + Company items)\n// ============================================\n\nconst allItems = $input.all();\n\n// Separate: PDF items have 'text' field, company items have 'row_number'\nconst pdfItems = allItems.filter(item => item.json.text !== undefined);\nconst companyNames = allItems\n  .filter(item => item.json.row_number !== undefined && item.json.companyName)\n  .map(item => item.json.companyName);\n\n// Fallback for company names\nconst finalCompanyNames = companyNames.length > 0 ? companyNames\n  : $('Get Master company list').all().map(item => item.json.companyName || '').filter(n => n);\n\nreturn pdfItems.map((item, index) => {\n  const text = item.json.text || '';\n  const fileId = item.json.fileId || '';\n  const fileName = item.json.fileName || '';\n\n  // Skip items without real fileId (no fake fallbacks)\n  if (!fileId || !text) return null;\n\n  const prompt = `You are a Turkish tax document parser. Extract structured data from the following PDF text.\n\nPDF Text:\n---\n${text.substring(0, 4000)}\n---\n\nFile Name: ${fileName}\nFile ID: ${fileId}\n\nCompany List (match the extracted company name to the closest one):\n${finalCompanyNames.join('\\n')}\n\nReturn ONLY valid JSON:\n{\n  \"fileId\": \"${fileId}\",\n  \"companyName\": \"company name from document\",\n  \"matchedCompany\": \"closest match from Company List, or null\",\n  \"taxType\": \"KDV|KDV Tevkifat|SGK|Muhtasar|Kurumlar|Kurumlar Geçici\",\n  \"monthNumber\": \"MM or null\",\n  \"monthName\": \"Turkish month name or null\",\n  \"year\": \"YYYY or null\",\n  \"amount\": 0,\n  \"confidence\": 0.0\n}\n\nRules:\n- Ignore prefixes: TASF. HAL., TASFİYE HALİNDE and suffixes: LİMİTED ŞİRKETİ\n- SOYADI (UNVANI) = company name, Vergilendirme Dönemi = period\n- TOPLAM or ÖDENECEK = amount (Turkish format 1.234,56)`;\n\n  return {\n    json: {\n      fileId: fileId,\n      fileName: fileName,\n      aiPrompt: prompt\n    }\n  };\n}).filter(item => item !== null);"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1860,
        300
      ],
      "id": "code-prepare-prompt",
      "name": "Prepare AI Prompt"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.1,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.aiPrompt) }}\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        2100,
        300
      ],
      "id": "ai-extract",
      "name": "AI Extract Tax Data",
      "credentials": {
        "openAiApi": {
          "id": "UgxxU7JRYK5Qpel4",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Parse AI response and match with company data\n// ============================================\n\nconst items = $input.all();\n\n// Get file metadata from Prepare AI Prompt (by fileId)\nconst promptItems = $('Prepare AI Prompt').all();\nconst promptByFileId = new Map();\nfor (const p of promptItems) {\n  if (p.json.fileId) promptByFileId.set(p.json.fileId, p.json);\n}\n\n// Build company lookup ONCE from Master Sheet (not from each item)\nconst companies = $('Get Master company list').all().map(item => {\n  const d = item.json;\n  return {\n    name: d.companyName || '',\n    taxFolderName: d.taxFolderName || '',\n    taxFolderId: d.taxFolderId || '',\n    contactPhone: d.contact_phone || '',\n    contactId: d.contact_id || '',\n    kommoCompanyId: d.kommoCompanyId || d['kommo_company_id'] || '',\n    kommoContactId: d.kommoContactId || d['kommo_contact_id'] || '',\n    companyId: d['company İD'] || d['Company ID'] || d['company_id'] || ''\n  };\n}).filter(c => c.name);\n\nreturn items.map((item, idx) => {\n  const d = item.json;\n  \n  // Parse the AI response\n  let aiResult = {};\n  try {\n    const content = d.choices?.[0]?.message?.content || '{}';\n    aiResult = JSON.parse(content);\n  } catch (e) {\n    aiResult = { companyName: null, matchedCompany: null, taxType: 'Bilinmeyen',\n      monthNumber: null, monthName: null, year: null, amount: 0, confidence: 0 };\n  }\n\n  // Get file metadata by fileId, fallback to index\n  const aiFileId = aiResult.fileId || '';\n  const promptData = promptByFileId.get(aiFileId) || promptItems[idx]?.json || {};\n  const fileId = promptData.fileId || aiFileId || '';\n  const fileName = promptData.fileName || '';\n\n  // Find matched company from Master Sheet\n  const matchedCompanyName = aiResult.matchedCompany;\n  let matchedCompany = null;\n  \n  if (matchedCompanyName) {\n    const normalized = matchedCompanyName.toLowerCase().trim();\n    matchedCompany = companies.find(c => c.name.toLowerCase().trim() === normalized);\n    if (!matchedCompany) {\n      matchedCompany = companies.find(c => {\n        const n = c.name.toLowerCase().trim();\n        return n.includes(normalized) || normalized.includes(n);\n      });\n    }\n  }\n\n  const isMatched = !!matchedCompany;\n  const confidence = aiResult.confidence || 0;\n  const amount = aiResult.amount || 0;\n  let formattedAmount = '0,00 ₺';\n  try { formattedAmount = new Intl.NumberFormat('tr-TR', { style: 'currency', currency: 'TRY' }).format(amount); } catch (e) {}\n\n  return {\n    json: {\n      fileId, fileName,\n      companyName: aiResult.companyName || 'غير محدد',\n      matchedCompanyName: matchedCompanyName || null,\n      taxType: aiResult.taxType || 'Bilinmeyen',\n      monthNumber: aiResult.monthNumber || null,\n      monthName: aiResult.monthName || null,\n      year: aiResult.year || null,\n      amount, formattedAmount, confidence,\n      isMatched,\n      taxFolderId: matchedCompany?.taxFolderId || null,\n      taxFolderName: matchedCompany?.taxFolderName || null,\n      contactPhone: matchedCompany?.contactPhone || null,\n      contactId: matchedCompany?.contactId || null,\n      kommoCompanyId: matchedCompany?.kommoCompanyId || null,\n      kommoContactId: matchedCompany?.kommoContactId || null,\n      companyId: matchedCompany?.companyId || null,\n      status: isMatched ? 'matched' : 'unmatched',\n      message: isMatched \n        ? `تم المطابقة: ${matchedCompanyName} (${Math.round(confidence * 100)}%)`\n        : `لم يتم المطابقة: ${aiResult.companyName || fileName}`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        2340,
        300
      ],
      "id": "code-parse-response",
      "name": "Parse AI Response"
