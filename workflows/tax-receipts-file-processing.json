    {
      "parameters": {
        "jsCode": "// ============================================\n// Combine extracted PDF text with file metadata\n// ============================================\n// Extract from File wipes original JSON data, so we recover\n// file metadata from the Download node (within this loop iteration)\nconst items = $input.all();\nconst downloadItem = $('Download file').first();\n\nreturn items.map(item => {\n  return {\n    json: {\n      // Extracted PDF data\n      text: item.json.text || '',\n      numpages: item.json.numpages || 0,\n      // File metadata recovered from Download node\n      fileId: downloadItem.json.id || '',\n      fileName: downloadItem.json.name || ''\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1440,
        200
      ],
