    {
      "parameters": {
        "jsCode": "// ============================================\n// Filter: only matched records that need Kommo sync\n// Get unique companies from today's matched records\n// ============================================\n\nconst reportItems = $('Get Monthly report').all();\nconst masterItems = $('Get Master company list').all();\n\n// Build master lookup by company name\nconst masterMap = {};\nfor (const item of masterItems) {\n  const name = (item.json.companyName || '').trim();\n  if (name) masterMap[name.toLowerCase()] = item.json;\n}\n\n// Filter matched records from today that have a companyName\nconst today = new Date().toISOString().split('T')[0];\nconst todayRecords = reportItems.filter(item => {\n  const d = item.json;\n  return d.status === 'matched' && d.companyName;\n});\n\n// Deduplicate by company name (we only need to sync each company once)\nconst seenCompanies = new Set();\nconst uniqueCompanies = [];\n\nfor (const item of todayRecords) {\n  const name = (item.json.companyName || '').trim().toLowerCase();\n  if (name && !seenCompanies.has(name)) {\n    seenCompanies.add(name);\n    const master = masterMap[name] || {};\n    uniqueCompanies.push({\n      json: {\n        companyName: item.json.companyName,\n        contactPhone: master.contact_phone || item.json.contactPhone || '',\n        contactName: master.contact_first_name || master.contactName || '',\n        contactLastName: master.contact_last_name || '',\n        contactEmail: master.contact_email || '',\n        kommoCompanyId: master.kommoCompanyId || master.kommo_company_id || '',\n        kommoContactId: master.kommoContactId || master.kommo_contact_id || '',\n        driveFolderId: master.taxFolderId || item.json.driveFolderId || '',\n        // Pass latest tax info for WhatsApp message\n        taxType: item.json.taxType || '',\n        month: item.json.month || '',\n        year: item.json.year || '',\n        amount: item.json.amount || ''\n      }\n    });\n  }\n}\n\nif (uniqueCompanies.length === 0) {\n  return [{ json: { _noRecords: true, message: 'No companies to sync' } }];\n}\n\nreturn uniqueCompanies;"
      },
