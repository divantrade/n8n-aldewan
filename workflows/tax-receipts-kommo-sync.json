    {
      "parameters": {
        "jsCode": "// ============================================\n// Check contact search result\n// If found: verify phone, extract contact_id\n// If not: prepare for creation\n// ============================================\n\nconst items = $input.all();\nconst origItems = $('Kommo Contact ID exists?').all();\n\nreturn items.map((item, index) => {\n  const response = item.json;\n  const orig = origItems[index]?.json || {};\n  \n  const contacts = response._embedded?.contacts || [];\n  const found = contacts.length > 0;\n  \n  let contactId = '';\n  let existingPhone = '';\n  let phoneMatch = false;\n  \n  if (found) {\n    const contact = contacts[0];\n    contactId = String(contact.id);\n    \n    // Extract phone from contact's custom fields\n    if (contact.custom_fields_values) {\n      const phoneField = contact.custom_fields_values.find(f => \n        f.field_code === 'PHONE' || f.field_name === 'Phone'\n      );\n      if (phoneField && phoneField.values && phoneField.values.length > 0) {\n        existingPhone = phoneField.values[0].value || '';\n      }\n    }\n    \n    // Check if phone matches\n    const cleanPhone = (p) => (p || '').replace(/[^+\\d]/g, '');\n    phoneMatch = cleanPhone(existingPhone) === cleanPhone(orig.contactPhone);\n  }\n  \n  return {\n    json: {\n      ...orig,\n      kommoContactFound: found,\n      kommoContactId: contactId,\n      existingPhone: existingPhone,\n      phoneMatch: phoneMatch,\n      needsPhoneUpdate: found && !phoneMatch && orig.contactPhone\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
