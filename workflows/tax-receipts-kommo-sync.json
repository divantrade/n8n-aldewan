      "name": "Get Contact for WhatsApp"
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Extract chat_id for WhatsApp sending\n// ============================================\n\nconst items = $input.all();\nconst masterItems = $('Update Master Sheet with IDs').all();\n\nreturn items.map((item, index) => {\n  const contact = item.json;\n  const masterData = masterItems[index]?.json || {};\n  \n  let chatId = null;\n  \n  // Try to get chat_id from _embedded.chats\n  if (contact._embedded?.chats) {\n    const chats = contact._embedded.chats;\n    // Find WhatsApp chat\n    const whatsappChat = Object.values(chats).find(chat => \n      chat.origin === 'whatsapp' || (chat.origin && chat.origin.includes('whatsapp'))\n    );\n    if (whatsappChat) {\n      chatId = whatsappChat.chat_id || whatsappChat.id;\n    }\n    // Fallback to first available chat\n    if (!chatId) {\n      const firstChat = Object.values(chats)[0];\n      if (firstChat) {\n        chatId = firstChat.chat_id || firstChat.id;\n      }\n    }\n  }\n\n  return {\n    json: {\n      contact_id: masterData.kommoContactId || contact.id,\n      chat_id: chatId,\n      companyName: masterData.companyName,\n      taxType: masterData.taxType || '',\n      month: masterData.month || '',\n      year: masterData.year || '',\n      amount: masterData.amount || '',\n      canSendWhatsApp: !!chatId\n    }\n  };\n});"
      },
