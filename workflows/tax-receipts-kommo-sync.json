        "jsCode": "// ============================================\n// Check if company was found in Kommo search\n// If found: extract company ID\n// If not: prepare data for creation\n// ============================================\n\nconst items = $input.all();\nconst prepareItems = $('Has records to sync?').all();\n\nreturn items.map((item, index) => {\n  const response = item.json;\n  const original = prepareItems.find(p => !p.json._noRecords) || prepareItems[index] || { json: {} };\n  const origData = original.json;\n  \n  const companies = response._embedded?.companies || [];\n  const found = companies.length > 0;\n  \n  return {\n    json: {\n      ...origData,\n      kommoCompanyFound: found,\n      kommoCompanyId: found ? String(companies[0].id) : '',\n      kommoCompanyName: found ? companies[0].name : origData.companyName\n    }\n  };\n});"
