    {
      "parameters": {
        "jsCode": "// Extract chat_id from Kommo contact response\nconst items = $input.all();\nconst parseData = $('Parse AI Response').all();\n\nreturn items.map((item, index) => {\n  const contact = item.json;\n  const parsed = parseData[index]?.json || {};\n  \n  // Extract chat_id from contact's chats\n  let chatId = null;\n  \n  // Try to get chat_id from _embedded.chats\n  if (contact._embedded?.chats) {\n    const chats = contact._embedded.chats;\n    // Find WhatsApp chat\n    const whatsappChat = Object.values(chats).find(chat => \n      chat.origin === 'whatsapp' || chat.origin?.includes('whatsapp')\n    );\n    if (whatsappChat) {\n      chatId = whatsappChat.chat_id || whatsappChat.id;\n    }\n    // If no WhatsApp chat found, use the first available chat\n    if (!chatId) {\n      const firstChat = Object.values(chats)[0];\n      if (firstChat) {\n        chatId = firstChat.chat_id || firstChat.id;\n      }\n    }\n  }\n\n  return {\n    json: {\n      contact_id: parsed.contactId || contact.id,\n      chat_id: chatId,\n      companyName: parsed.matchedCompanyName,\n      taxType: parsed.taxType,\n      monthName: parsed.monthName,\n      year: parsed.year,\n      formattedAmount: parsed.formattedAmount,\n      canSendWhatsApp: !!chatId && !!parsed.contactId\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
