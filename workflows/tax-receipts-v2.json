        1040,
        400
      ],
      "id": "merge-data",
      "name": "Merge PDF + Companies"
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Prepare AI prompt: combine PDF text with company list\n// ============================================\n\nconst items = $input.all();\n\n// Get company list from the Get company list node\nconst companies = $('Get company list').all().map(item => {\n  const d = item.json;\n  return {\n    name: d.companyName || d['companyName'] || '',\n    taxFolderName: d.taxFolderName || '',\n    taxFolderId: d.taxFolderId || '',\n    contactPhone: d.contact_phone || '',\n    contactId: d.contact_id || '',\n    companyId: d['company İD'] || d['Company ID'] || d['company ID'] || ''\n  };\n}).filter(c => c.name);\n\nconst companyNames = companies.map(c => c.name);\n\n// For each PDF item, prepare the AI prompt\nreturn items.map(item => {\n  const text = item.json.text || '';\n  const fileName = item.json.name || item.json.fileName || '';\n  const fileId = item.json.id || '';\n\n  const prompt = `You are a Turkish tax document parser. Extract structured data from the following PDF text.\n\nPDF Text:\n---\n${text.substring(0, 4000)}\n---\n\nFile Name: ${fileName}\n\nCompany List (match the extracted company name to the closest one from this list):\n${companyNames.join('\\n')}\n\nExtract the following and return ONLY valid JSON (no markdown, no explanation):\n{\n  \"companyName\": \"the company name as found in the document\",\n  \"matchedCompany\": \"the closest matching company name from the Company List above, or null if no match\",\n  \"taxType\": \"one of: KDV, KDV Tevkifat, SGK, Muhtasar, Kurumlar, Kurumlar Geçici, or the detected type\",\n  \"monthNumber\": \"MM format (01-12) or null\",\n  \"monthName\": \"Turkish month name (Ocak, Şubat, etc.) or null\",\n  \"year\": \"YYYY format or null\",\n  \"amount\": numeric amount or 0,\n  \"confidence\": confidence score 0.0 to 1.0\n}\n\nIMPORTANT:\n- For company name matching: ignore liquidation prefixes (TASF. HAL., TASFİYE HALİNDE, etc.) and legal suffixes (LİMİTED ŞİRKETİ, etc.)\n- For SGK documents: look for İşyeri Ünvanı or Unvanı fields\n- For tax documents: look for SOYADI (UNVANI) field\n- For tax type: check for KDV (Katma Değer Vergisi), SGK (Sosyal Güvenlik), Muhtasar, Kurumlar Vergisi\n- For period: look for Vergilendirme Dönemi, AİT OLDUĞU YIL/AY\n- For amount: look for ÖDENECEK NET TUTAR, TOPLAM, or similar fields. Parse Turkish number format (1.234,56)`;\n\n  return {\n    json: {\n      fileId: fileId,\n      fileName: fileName,\n      pdfText: text,\n      aiPrompt: prompt,\n      companyListJson: JSON.stringify(companies)\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1280,
        400
      ],
      "id": "code-prepare-prompt",
      "name": "Prepare AI Prompt"
    },
    {
      "parameters": {
        "method": "POST",
        "url": "https://api.openai.com/v1/chat/completions",
        "authentication": "predefinedCredentialType",
        "nodeCredentialType": "openAiApi",
        "sendBody": true,
        "specifyBody": "json",
        "jsonBody": "={\n  \"model\": \"gpt-4o-mini\",\n  \"temperature\": 0.1,\n  \"response_format\": { \"type\": \"json_object\" },\n  \"messages\": [\n    {\n      \"role\": \"user\",\n      \"content\": {{ JSON.stringify($json.aiPrompt) }}\n    }\n  ]\n}",
        "options": {}
      },
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        1520,
        400
      ],
      "id": "ai-extract",
      "name": "AI Extract Tax Data",
      "credentials": {
        "openAiApi": {
          "id": "UgxxU7JRYK5Qpel4",
          "name": "OpenAi account"
        }
      }
    },
    {
      "parameters": {
        "jsCode": "// ============================================\n// Parse AI response and match with company data\n// ============================================\n\nconst items = $input.all();\n\nreturn items.map(item => {\n  const d = item.json;\n  \n  // Parse the AI response\n  let aiResult = {};\n  try {\n    const content = d.choices?.[0]?.message?.content || '{}';\n    aiResult = JSON.parse(content);\n  } catch (e) {\n    aiResult = {\n      companyName: null,\n      matchedCompany: null,\n      taxType: 'Bilinmeyen',\n      monthNumber: null,\n      monthName: null,\n      year: null,\n      amount: 0,\n      confidence: 0\n    };\n  }\n\n  // Get the original file data from Prepare AI Prompt node\n  const promptItems = $('Prepare AI Prompt').all();\n  const currentIndex = items.indexOf(item);\n  const promptData = promptItems[currentIndex]?.json || {};\n  const fileId = promptData.fileId || '';\n  const fileName = promptData.fileName || '';\n  \n  // Get company list and find the matched company's details\n  let companies = [];\n  try {\n    companies = JSON.parse(promptData.companyListJson || '[]');\n  } catch (e) {\n    companies = [];\n  }\n\n  const matchedCompanyName = aiResult.matchedCompany;\n  let matchedCompany = null;\n  \n  if (matchedCompanyName) {\n    // Find the company details from our list\n    matchedCompany = companies.find(c => \n      c.name === matchedCompanyName ||\n      c.name.toLowerCase().trim() === matchedCompanyName.toLowerCase().trim()\n    );\n    \n    // Fuzzy fallback: check if names contain each other\n    if (!matchedCompany) {\n      const normalizedMatch = matchedCompanyName.toLowerCase().trim();\n      matchedCompany = companies.find(c => {\n        const normalizedName = c.name.toLowerCase().trim();\n        return normalizedName.includes(normalizedMatch) || normalizedMatch.includes(normalizedName);\n      });\n    }\n  }\n\n  const isMatched = !!matchedCompany;\n  const confidence = aiResult.confidence || 0;\n\n  // Format amount in Turkish locale\n  const amount = aiResult.amount || 0;\n  let formattedAmount = '0,00 ₺';\n  try {\n    formattedAmount = new Intl.NumberFormat('tr-TR', {\n      style: 'currency',\n      currency: 'TRY'\n    }).format(amount);\n  } catch (e) {}\n\n  return {\n    json: {\n      // File info\n      fileId: fileId,\n      fileName: fileName,\n      \n      // AI extracted data\n      companyName: aiResult.companyName || 'غير محدد',\n      matchedCompanyName: matchedCompanyName || null,\n      taxType: aiResult.taxType || 'Bilinmeyen',\n      monthNumber: aiResult.monthNumber || null,\n      monthName: aiResult.monthName || null,\n      year: aiResult.year || null,\n      amount: amount,\n      formattedAmount: formattedAmount,\n      confidence: confidence,\n      \n      // Company details (from Google Sheet)\n      isMatched: isMatched,\n      taxFolderId: matchedCompany?.taxFolderId || null,\n      taxFolderName: matchedCompany?.taxFolderName || null,\n      contactPhone: matchedCompany?.contactPhone || null,\n      contactId: matchedCompany?.contactId || null,\n      companyId: matchedCompany?.companyId || null,\n      \n      // Status\n      status: isMatched ? 'matched' : 'unmatched',\n      message: isMatched \n        ? `✅ تم المطابقة: ${matchedCompanyName} (${Math.round(confidence * 100)}%)`\n        : `❌ لم يتم المطابقة: ${aiResult.companyName || fileName}`\n    }\n  };\n});"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
      "position": [
        1760,
        400
      ],
      "id": "code-parse-response",
      "name": "Parse AI Response"
